# Copy this file to ".env" in the project root and fill in your real keys.
# Never commit the real .env file to GitHub.

# REQUIRED — Overview Agent + Aggregator Agent + Safety Gate
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# REQUIRED — Video Agent
# Enable "YouTube Data API v3" at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# OPTIONAL — Paper Agent (works without a key at a lower rate limit)
# Get a free key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OPTIONAL — Book Agent (works without a key at a lower rate limit)
# Enable "Books API" at: https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# Which Gemini model to use
GEMINI_MODEL=gemini-2.0-flash
